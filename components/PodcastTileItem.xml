<?xml version="1.0" encoding="utf-8" ?>
<component name="PodcastTileItem" extends="Group">
  <interface>
    <field id="itemContent"  type="node"    onChange="onContentSet" />
    <field id="focusPercent" type="float"   onChange="onFocus" />
    <field id="isNowPlaying" type="boolean" value="false" onChange="onNowPlayingChanged" />
  </interface>
  <children>
    <Rectangle id="focusBorder" width="864" height="94" translation="[-2,-2]"
               color="0x00A0E8FF" visible="false" />
    <Rectangle id="bg" width="860" height="90" color="0x1A1B1DFF" />
    <Poster id="art" width="90" height="90" translation="[0,0]"
            loadDisplayMode="scaleToZoom" />
    <!-- Vertical divider between art and text -->
    <Rectangle translation="[98,8]" width="2" height="74" color="0x2A2D32FF" />
    <Label id="titleLabel" translation="[110,8]" width="700" height="46"
           font="font:SmallBoldSystemFont" color="0xFFFFFFFF"
           wrap="true" />
    <Label id="podcastLabel" translation="[110,56]" width="460" height="22"
           font="font:SmallestSystemFont" color="0x9C9FA4FF" />
    <Label id="timeLabel" translation="[640,56]" width="210" height="22"
           font="font:SmallestSystemFont" color="0x9C9FA4FF"
           horizAlign="right" />
    <Rectangle id="nowBg" width="52" height="22" translation="[804,4]"
               color="0x00A0E8FF" visible="false" />
    <Label id="nowLabel" translation="[804,4]" width="52" height="22"
           font="font:SmallestSystemFont" color="0x000000FF"
           horizAlign="center" vertAlign="center"
           text="NOW" visible="false" />
  </children>
  <script type="text/brightscript" uri="pkg:/components/PodcastTileItem.brs" />
</component>
